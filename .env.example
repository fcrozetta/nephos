# Initial local Nephos API config.
# Nephos manages the first-party core-registry checkout itself under:
#   .nephos/registries/core-registry
NEPHOS_API_DB_PATH=.nephos/state/nephos.db
# Required (no default): the internal root domain for generated App routes.
NEPHOS_API_INTERNAL_DOMAIN=nephos.lcl

# Optional registry overrides for development/testing. Leave unset for the default
# first-party core registry.
# NEPHOS_API_CORE_REGISTRY_URL=https://git.fcrozetta.app/nephos/core-registry.git
# NEPHOS_API_CORE_REGISTRY_PATH=.nephos/registries/core-registry

# Optional escape hatch for local catalog experiments. When set, this replaces
# the managed core-registry dependency set instead of adding to it.
# NEPHOS_API_CATALOG_ROOTS=/path/to/catalog-root

# Runtime/Kubernetes settings are optional for initial config + catalog checks.
# Enable them only when testing reconciliation against a disposable local cluster.
# NEPHOS_API_KUBE_CONTEXT=docker-desktop
# NEPHOS_API_KUBECONFIG=~/.kube/config
# NEPHOS_API_INGRESS_CLASS=nginx
# PULUMI_CONFIG_PASSPHRASE=local-dev
# NEPHOS_API_RUN_KUBERNETES_TESTS=1
